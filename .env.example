# CardLens environment configuration (example).
# Copy to .env and fill values. .env is gitignored. Never commit real secrets.
# All variables are consumed through the typed Settings object (backend/app/config.py).

# --- App ---
CARDLENS_ENV=local
CARDLENS_DEBUG=true
CARDLENS_APP_NAME=CardLens
CARDLENS_API_PREFIX=/api/v1
CARDLENS_HOST=0.0.0.0
CARDLENS_PORT=8000
CARDLENS_CORS_ORIGINS=http://localhost:3000

# --- Database ---
# Local default uses SQLite (zero setup). For Postgres parity:
# CARDLENS_DATABASE_URL=postgresql+psycopg://cardlens:cardlens@localhost:5432/cardlens
CARDLENS_DATABASE_URL=sqlite:///./cardlens.db

# --- Security (generate strong values for non-local) ---
CARDLENS_JWT_SECRET=change-me-in-non-local
CARDLENS_JWT_ALGORITHM=HS256
CARDLENS_ACCESS_TOKEN_TTL_MINUTES=30
CARDLENS_REFRESH_TOKEN_TTL_DAYS=14
# Fernet key for encrypting stored OAuth tokens (generate with cryptography.fernet).
CARDLENS_TOKEN_ENCRYPTION_KEY=

# --- Logging ---
CARDLENS_LOG_LEVEL=DEBUG
CARDLENS_LOG_DIR=logs/local
CARDLENS_LOG_MAX_BYTES=10485760
CARDLENS_LOG_BACKUP_COUNT=5
CARDLENS_LOG_JSON=true

# --- Ingestion / scheduler ---
CARDLENS_SCHEDULER_ENABLED=false
CARDLENS_SCAN_INTERVAL_HOURS=6
CARDLENS_SCAN_LOOKBACK_HOURS=24
# When true, Gmail calls are mocked (no real Google credentials required).
CARDLENS_GMAIL_DRY_RUN=true

# --- Google OAuth (leave blank to stay in dry-run/mock) ---
CARDLENS_GOOGLE_CLIENT_ID=
CARDLENS_GOOGLE_CLIENT_SECRET=
CARDLENS_GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/mail/accounts/callback

# --- Azure (leave blank to use local/mock providers) ---
CARDLENS_AZURE_BLOB_CONNECTION_STRING=
CARDLENS_AZURE_BLOB_CONTAINER=cardlens-statements
CARDLENS_AZURE_KEYVAULT_URL=
CARDLENS_AZURE_DOCINTEL_ENDPOINT=
CARDLENS_AZURE_DOCINTEL_KEY=
CARDLENS_AZURE_APPINSIGHTS_CONNECTION_STRING=

# --- Document vault (opt-in raw PDF retention) ---
CARDLENS_DOCUMENT_VAULT_ENABLED=false
CARDLENS_RETAIN_RAW_PDF=false

# --- Config data files (externalized domain data; relative to backend/) ---
CARDLENS_CONFIG_DIR=app/shared/config/data
CARDLENS_CARD_REGISTRY_DIR=../card_registry
