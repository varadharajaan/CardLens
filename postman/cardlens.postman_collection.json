                  "var b = pm.response.json();",
                  "pm.test('key matches', function () { pm.expect(b.key).to.eql(pm.environment.get('reg_key')); });"
                ]
              }
            }
          ]
        },
        {
          "name": "List Cards",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/registry/cards?page=1&size=20", "host": ["{{base_url}}"], "path": ["api", "v1", "registry", "cards"], "query": [ { "key": "page", "value": "1" }, { "key": "size", "value": "20" } ] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var b = pm.response.json();",
                  "pm.test('items is array', function () { pm.expect(b.items).to.be.an('array'); });",
                  "pm.test('total at least 1', function () { pm.expect(b.total).to.be.at.least(1); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Card By Key",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/registry/cards/{{reg_key}}", "host": ["{{base_url}}"], "path": ["api", "v1", "registry", "cards", "{{reg_key}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var b = pm.response.json();",
                  "pm.test('bank HDFC', function () { pm.expect(b.bank).to.eql('HDFC'); });",
                  "pm.test('key matches', function () { pm.expect(b.key).to.eql(pm.environment.get('reg_key')); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Match Card",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bank\": \"HDFC\",\n  \"card_name\": \"{{reg_card_name}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/registry/cards/match", "host": ["{{base_url}}"], "path": ["api", "v1", "registry", "cards", "match"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "var b = pm.response.json();",
                  "pm.test('matched true', function () { pm.expect(b.matched).to.be.true; });",
                  "pm.test('matched our key', function () { pm.expect(b.key).to.eql(pm.environment.get('reg_key')); });"
