                ]
              }
            }
          ]
        },
        {
          "name": "Register - invalid input (422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"short\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 422', function () { pm.response.to.have.status(422); });",
                  "var b = pm.response.json();",
                  "pm.test('errorCode VALIDATION_FAILED', function () { pm.expect(b.errorCode).to.eql('VALIDATION_FAILED'); });",
                  "pm.test('violations array', function () { pm.expect(b.violations).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Upsert Card - no token (401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schema_version\": \"1\",\n  \"key\": \"qa-noauth-{{request_id}}\",\n  \"bank\": \"HDFC\",\n  \"card_name\": \"No Auth Card\",\n  \"network\": \"VISA\",\n  \"version\": 1,\n  \"source_confidence\": 0.5,\n  \"last_verified_at\": \"2026-01-01\",\n  \"features\": {}\n}",
              "options": { "raw": { "language": "json" } }
            },
