                  "pm.test('errorCode VALIDATION_FAILED', function () { pm.expect(pm.response.json().errorCode).to.eql('VALIDATION_FAILED'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh - replay consumed token (401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{consumed_refresh_token}}\"\n}",
