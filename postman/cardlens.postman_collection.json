    },
    {
      "name": "Error Scenarios",
      "item": [
        {
          "name": "Get Me - no token (401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/users/me", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "me"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 401', function () { pm.response.to.have.status(401); });",
                  "pm.test('errorCode UNAUTHENTICATED', function () { pm.expect(pm.response.json().errorCode).to.eql('UNAUTHENTICATED'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Me - tampered token (401)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" },
              { "key": "Authorization", "value": "Bearer not.a.valid.jwt" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/users/me", "host": ["{{base_url}}"], "path": ["api", "v1", "users", "me"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 401', function () { pm.response.to.have.status(401); });",
                  "pm.test('errorCode UNAUTHENTICATED', function () { pm.expect(pm.response.json().errorCode).to.eql('UNAUTHENTICATED'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Card - unknown key (404)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/registry/cards/does-not-exist-{{request_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "registry", "cards", "does-not-exist-{{request_id}}"] }
