        {
          "name": "Upsert Card - bad network (422)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schema_version\": \"1\",\n  \"key\": \"qa-badnet-{{request_id}}\",\n  \"bank\": \"HDFC\",\n  \"card_name\": \"Bad Network Card\",\n  \"network\": \"BITCOIN\",\n  \"version\": 1,\n  \"source_confidence\": 0.5,\n  \"last_verified_at\": \"2026-01-01\",\n  \"features\": {}\n}",
