              { "key": "Accept", "value": "application/json" },
              { "key": "X-Request-Id", "value": "{{request_id}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schema_version\": \"1\",\n  \"key\": \"{{reg_key}}\",\n  \"bank\": \"HDFC\",\n  \"card_name\": \"{{reg_card_name}}\",\n  \"network\": \"VISA\",\n  \"version\": 1,\n  \"source_confidence\": 0.5,\n  \"last_verified_at\": \"2026-01-01\",\n  \"features\": { \"annual_fee\": 1000 }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/registry/cards", "host": ["{{base_url}}"], "path": ["api", "v1", "registry", "cards"] }
          },
          "event": [
